{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    },
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "^/api/courses$",
      "dest": "/api/courses.js"
    },
    {
      "src": "^/api/courses/(.*)$",
      "dest": "/api/courses/[id].js"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
